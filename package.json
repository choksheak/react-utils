{
  "name": "@choksheak/react-utils",
  "license": "The Unlicense",
  "version": "0.4.1",
  "packageManager": "pnpm@10.18.3",
  "pnpm": {
    "packageExtensions": {
      "@choksheak/ts-utils": {
        "dependencies": {
          "simple-git-hooks": "^2.13.1"
        }
      }
    }
  },
  "description": "Miscellaneous React+TypeScript utilities with support for full tree-shaking.",
  "private": false,
  "sideEffects": false,
  "scripts": {
    "lint": "eslint .",
    "fix": "eslint . --fix",
    "tsc": "tsc",
    "ft": "pnpm run fix && pnpm run tsc",
    "build": "tsx scripts/gen-index.ts && tsup src/*",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "pnpm run lint && pnpm run tsc && pnpm run build && pnpm run test",
    "ls": "lint-staged",
    "clean": "rm -rf dist",
    "docs": "typedoc",
    "gen-types": "tsc --emitDeclarationOnly --declaration",
    "gen-exports": "tsx scripts/gen-exports.ts",
    "pkg": "scripts/package.sh",
    "pub": "pnpm publish dist/",
    "commit": "git add . && git commit -m 'Release '`bump-version get`",
    "release": "pnpm run clean && bump-version && pnpm install && pnpm run ci && pnpm run pkg && pnpm run commit && pnpm run pub",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "echo Using `eslint --fix` will revert changes without printing errors!",
      "eslint ."
    ],
    "*.{ts,tsx}": [
      "echo `tsc-files --noEmit` cannot read *.module.css files",
      "bash -c 'pnpm exec tsc'"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/choksheak/react-utils.git"
  },
  "keywords": [
    "chok",
    "react",
    "utils",
    "typescript",
    "library"
  ],
  "author": "ChokSheak Lau",
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "files": [
    "*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/choksheak/react-utils#readme",
  "devDependencies": {
    "@choksheak/bump-version": "^0.1.2",
    "@choksheak/ts-utils": "^0.3.8",
    "@eslint/compat": "^1.4.0",
    "@eslint/js": "^9.38.0",
    "@swc/core": "^1.14.0",
    "@types/jest": "^30.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/xxhashjs": "^0.2.4",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.38.0",
    "eslint-config": "^0.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.4.0",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.6",
    "object-sizeof": "^2.6.5",
    "prettier": "^3.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typedoc": "^0.28.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.2",
    "use-deep-compare": "^1.3.0",
    "vitest": "^4.0.3"
  },
  "peerDependencies": {
    "@choksheak/ts-utils": ">=0.3.8",
    "react": ">=16"
  },
  "dependencies": {
    "lodash-es": "^4.18.1",
    "object-sizeof": ">=2.6.5",
    "use-deep-compare": ">=1.3.0",
    "xxhashjs": ">=0.2.2"
  }
}
